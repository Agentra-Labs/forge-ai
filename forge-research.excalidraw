      "link": null,
      "locked": false,
      "text": "Pass 1 (skim): title / abstract / section headers / figures -> decide relevance  |  Pass 2 (structure): intro / conclusion / results / method outline -> map claims  |  Pass 3 (deep): full paper + math + proofs -> extract contributions / critique assumptions / flag reproducibility gaps",
      "fontSize": 13,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
