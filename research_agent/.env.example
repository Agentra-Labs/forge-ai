# AWS Credentials (for Amazon Nova on Bedrock)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1  # Nova models are primarily in us-east-1

# Optional: Anthropic (if you want to compare models) — works without key at lower rate limits)
OPENALEX_EMAIL=

# kernel.sh (optional — falls back to httpx scraping)
KERNEL_API_KEY=

# TinyFish (optional — falls back to basic extraction)
TINYFISH_API_KEY=